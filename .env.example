# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by the app at runtime.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# On Neon use the POOLED connection string (host contains "-pooler").
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/viral_finder?schema=public"

# Direct (non-pooled) connection used only by `prisma migrate`.
# On Neon this is the same URL WITHOUT "-pooler" in the host.
# Locally it can be identical to DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/viral_finder?schema=public"

# YouTube Data API v3 key.
# Create one at: https://console.cloud.google.com/apis/credentials
# Enable the "YouTube Data API v3" for your project first.
YOUTUBE_API_KEY="your-youtube-data-api-v3-key"

# Upstash Redis — per-IP rate limiting for the search action.
# Create a free database at https://console.upstash.com and copy the REST
# credentials. Optional locally (limiting is skipped when unset); REQUIRED in
# production so a single client can't exhaust the YouTube quota.
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"
